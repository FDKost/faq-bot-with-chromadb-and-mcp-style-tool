# Environment variables for FAQ Bot

# Path to persist ChromaDB
CHROMA_DB_PATH=./chroma_faq

# Ollama server URL (default: http://localhost:11434)
OLLAMA_URL=http://localhost:11434

# Ollama model name (default: llama3)
OLLAMA_MODEL=llama3

# Optional: FastAPI mock server URL
MOCK_SERVER_URL=http://localhost:8000
